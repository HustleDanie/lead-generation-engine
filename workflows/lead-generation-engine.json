    {
      "id": "apollo-mock",
      "name": "Apollo Fallback Mock",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1560,
        380
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const items = $input.all();\nconst apollo = ['google.com','meta.com','microsoft.com','example.com','acme.io','techco.com'];\nconst out = [];\nfor (const item of items) {\n  const email = item.json.email || '';\n  const domain = email.split('@')[1] || '';\n  if (apollo.includes(domain)) {\n    out.push({ json: { ...item.json, enriched_by: 'apollo', title: item.json.jobTitle || 'Senior Manager', linkedin: 'https://linkedin.com/in/' + (email.split('@')[0] || 'unknown'), company_size: 45, industry: 'Technology', revenue: 5000000, tech_stack: '' } });\n  } else {\n    out.push({ json: { ...item.json, enriched_by: 'none', apollo_miss: true, title: item.json.jobTitle || '', linkedin: '', company_size: 0, industry: '', revenue: 0, tech_stack: '' } });\n  }\n}\nreturn out;"
      }
    },
