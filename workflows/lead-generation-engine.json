    {
      "id": "score-lead",
      "name": "Score Lead (Rule Engine)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2000,
        320
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const items = $input.all();\nconst out = [];\nfor (const item of items) {\n  const d = item.json;\n  const title = (d.title || '').toLowerCase();\n  const size = Number(d.company_size) || 0;\n  const revenue = Number(d.revenue) || 0;\n  const enrichedBy = d.enriched_by;\n  const isExec = /\\b(chief|cto|ceo|cfo|coo|cpo|cmo|vp|vice president|director|head of)\\b/.test(title);\n  const isMgr = /\\b(manager|lead|principal|senior)\\b/.test(title);\n  let tier, reasoning, score;\n  if (!enrichedBy || enrichedBy === 'none') { tier = 'cold'; score = 10; reasoning = 'No enrichment data — cannot qualify'; }\n  else if (isExec && (size >= 50 || revenue >= 10000000)) { tier = 'hot'; score = 90; reasoning = 'Executive title at ' + size + '-employee company with $' + revenue + ' revenue'; }\n  else if (isExec || isMgr || size >= 10) { tier = 'warm'; score = 55; reasoning = 'Mid-level profile (title=' + (title || 'unknown') + ', size=' + size + ')'; }\n  else { tier = 'cold'; score = 25; reasoning = 'Thin profile or small company'; }\n  out.push({ json: { ...d, tier, reasoning, score_num: score } });\n}\nreturn out;"
      }
    },
