    {
      "id": "clearbit-mock",
      "name": "Clearbit Mock",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        260
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const items = $input.all();\nconst enriched = ['stripe.com','airbnb.com','shopify.com','notion.so','linear.app','vercel.com','anthropic.com'];\nconst out = [];\nfor (const item of items) {\n  const email = item.json.email || '';\n  const domain = email.split('@')[1] || '';\n  if (enriched.includes(domain)) {\n    out.push({ json: { ...item.json, enriched_by: 'clearbit', title: item.json.jobTitle || 'VP of Engineering', linkedin: 'https://linkedin.com/in/' + (email.split('@')[0] || 'unknown'), company_size: 250, industry: 'Software', revenue: 50000000, tech_stack: 'n8n, AWS, Postgres' } });\n  } else {\n    out.push({ json: { ...item.json, enriched_by: null, clearbit_miss: true } });\n  }\n}\nreturn out;"
      }
    },
